{
  "name": "cyberpunk-archive",
  "version": "1.0.0",
  "description": "A cyberpunk-themed digital archive with SQLite backend and Unsplash image integration",
  "main": "server/server.js",
  "type": "module",
  "scripts": {
    "start": "node --experimental-sqlite server/server.js",
    "dev": "node --experimental-sqlite --watch server/server.js",
    "seed": "node --experimental-sqlite server/seed.js",
    "seed:videos": "node --experimental-sqlite server/seed-videos.js",
    "seed:playlist": "node --experimental-sqlite server/seed-playlist.js",
    "seed:1980": "node --experimental-sqlite server/seed-playlist-1980.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3"
  }
}
